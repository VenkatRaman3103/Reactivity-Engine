{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "jsx": "react",
        "jsxFactory": "__h",
        "jsxFragmentFactory": "__Fragment",
        "baseUrl": ".",
        "paths": {
            "@engine/style": ["packages/style/src/index.ts"],
            "@engine/style/*": ["packages/style/src/*"],
            "@engine": ["src/index.ts"],
            "@engine/*": ["src/*"]
        },
        "types": ["node"]
    },
    "include": [
        "src",
        "compiler",
        "example",
        "packages"
    ]
}
